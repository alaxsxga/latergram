    "paywall.terms_disclosure": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Abo verlängert sich automatisch monatlich, sofern es nicht mindestens 24 Stunden vor Ablauf des aktuellen Zeitraums gekündigt wird. Die Zahlung erfolgt über deine Apple-ID. Du kannst das Abo jederzeit in den Einstellungen deines App-Store-Kontos verwalten oder kündigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscription auto-renews monthly unless cancelled at least 24 hours before the end of the current period. Payment is charged to your Apple ID. Manage or cancel anytime in your App Store account settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La suscripción se renueva automáticamente cada mes si no se cancela al menos 24 horas antes de que termine el periodo actual. El cargo se realiza en tu ID de Apple. Puedes gestionarla o cancelarla en cualquier momento desde los ajustes de tu cuenta de App Store."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Langganan diperpanjang otomatis setiap bulan kecuali dibatalkan setidaknya 24 jam sebelum periode berjalan berakhir. Pembayaran dikenakan ke Apple ID Anda. Anda dapat mengelola atau membatalkan kapan saja di pengaturan akun App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションは月単位で自動更新されます。期間終了の24時間前までにキャンセルしない場合、自動で更新され、Apple IDに請求されます。App Storeのアカウント設定からいつでも管理・解約できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독은 현재 기간이 끝나기 24시간 전까지 취소하지 않으면 매월 자동 갱신됩니다. 결제는 Apple ID 계정으로 청구되며, App Store 계정 설정에서 언제든지 관리하거나 취소할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A assinatura é renovada automaticamente todo mês, exceto se for cancelada com pelo menos 24 horas de antecedência em relação ao fim do período atual. A cobrança é feita no seu ID Apple. Você pode gerenciar ou cancelar a qualquer momento nas configurações da sua conta na App Store."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การสมัครสมาชิกจะต่ออายุอัตโนมัติทุกเดือน หากไม่ยกเลิกอย่างน้อย 24 ชั่วโมงก่อนสิ้นสุดรอบปัจจุบัน การชำระเงินจะเรียกเก็บผ่าน Apple ID ของคุณ คุณสามารถจัดการหรือยกเลิกได้ตลอดเวลาในการตั้งค่าบัญชี App Store"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訂閱為每月自動續訂，除非在當前期間結束前 24 小時取消，否則將自動續訂並由 Apple ID 扣款。可隨時於 App Store 帳號設定中管理或取消訂閱。"
          }
        }
      }
    },
