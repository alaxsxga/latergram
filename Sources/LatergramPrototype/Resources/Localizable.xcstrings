    "compose.paywall_hint_message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im Gratis-Plan sind Verzögerungen bis 24 Stunden möglich. Mit einem Upgrade kannst du bis zu 7 Tage einstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free plan supports delays up to 24 hours. Upgrade to set up to 7 days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El plan gratuito permite retrasos de hasta 24 horas. Mejora para configurar hasta 7 días."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Paket gratis menunda hingga 24 jam. Upgrade untuk mengatur hingga 7 hari."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無料プランの上限は24時間です。アップグレードすると最長7日まで設定できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무료 플랜은 최대 24시간 지연까지 지원해요. 업그레이드하면 최대 7일까지 설정할 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O plano gratuito permite atrasos de até 24 horas. Assine para definir até 7 dias."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แผนฟรีหน่วงเวลาได้ถึง 24 ชั่วโมง อัปเกรดเพื่อตั้งได้ถึง 7 วัน"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "免費版上限 24 小時，升級後最長可設 7 天"
          }
        }
      }
    },
