{
  "sourceLanguage": "en",
  "strings": {
    "auth.confirm_email_body": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir haben eine Bestätigungs-E-Mail an %@ geschickt\nTippe auf den Link, um zu diesem Bildschirm zurückzukehren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A verification email has been sent to %@\nClick the link to return to this page"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te enviamos un correo de verificación a %@\nToca el enlace para volver a esta pantalla"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kami mengirim email verifikasi ke %@\nKetuk tautan di email untuk kembali ke layar ini"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認メールを %@ に送信しました\nメール内のリンクをタップするとこの画面に戻ります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@(으)로 인증 메일을 보냈어요\n메일 속 링크를 누르면 이 화면으로 돌아와요"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviamos um e-mail de verificação para %@\nToque no link para voltar a esta tela"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เราส่งอีเมลยืนยันไปที่ %@ แล้ว\nแตะลิงก์ในอีเมลเพื่อกลับมาที่หน้านี้"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "驗證信已寄至 %@\n點擊信中連結後會自動返回此頁"
          }
        }
      }
    },
